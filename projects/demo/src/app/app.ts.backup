  version: string;
}

@Component({
  selector: 'app-root',
  standalone: true,
  imports: [CommonModule, FormsModule, JalaliDatePickerComponent],
  templateUrl: './app.html',
  styleUrls: ['./app.scss']
})
export class AppComponent {
  title = 'تقویم جلالی';
  selectedDate: Date = new Date();
  selectionMode: 'single' | 'range' | 'multiple' = 'single';
  selectedRange: { start: Date | null; end: Date | null } = { start: null, end: null };
  selectedDates: Date[] = [];
  currentLocale: SupportedLocale = 'fa';

  private texts: { [key in SupportedLocale]: DemoTexts } = {
    fa: {
      title: '📚 راهنمای استفاده از تقویم جلالی',
      subtitle: 'کامپوننت Angular برای تقویم فارسی با 21 تم و 4 زبان',
      installTitle: '📦 نصب کتابخانه',
      usageTitle: '💻 نحوه استفاده در پروژه',
      example1Title: '1️⃣ استفاده ساده (انتخاب تک تاریخ)',
      example1Desc: 'ساده‌ترین حالت استفاده برای انتخاب یک تاریخ:',
      example1Code: `import { JalaliDatePickerComponent } from 'jalali-date-picker';

@Component({
  selector: 'app-my-component',
  standalone: true,
  imports: [JalaliDatePickerComponent],
  template: \`
    <jalali-date-picker
      [selectedDate]="selectedDate"
      (dateSelect)="onDateSelect($event)">
    </jalali-date-picker>
  \`
})
export class MyComponent {
  selectedDate = new Date();
  
  onDateSelect(date: Date) {
    console.log('تاریخ انتخاب شده:', date);
  }
}`,
      example2Title: '2️⃣ انتخاب محدوده تاریخ',
      example2Desc: 'برای انتخاب دو تاریخ (از - تا):',
      example2Code: `<jalali-date-picker
  selectionMode="range"
  [selectedRange]="selectedRange"
  (rangeSelect)="onRangeSelect($event)">
</jalali-date-picker>

// در کامپوننت:
selectedRange = { start: null, end: null };

onRangeSelect(range: { start: Date; end: Date }) {
  console.log('از:', range.start);
  console.log('تا:', range.end);
}`,
      example3Title: '3️⃣ انتخاب چند تاریخ',
      example3Desc: 'برای انتخاب چندین تاریخ مختلف:',
      example3Code: `<jalali-date-picker
  selectionMode="multiple"
  [selectedDates]="selectedDates"
  (multipleSelect)="onMultipleSelect($event)">
</jalali-date-picker>

// در کامپوننت:
selectedDates: Date[] = [];

onMultipleSelect(dates: Date[]) {
  console.log('تاریخ‌های انتخاب شده:', dates);
}`,
      example4Title: '4️⃣ تنظیمات پیشرفته',
      example4Desc: 'استفاده با تنظیمات کامل (زبان، تم، محدودیت تاریخ):',
      example4Code: `<jalali-date-picker
  [selectedDate]="selectedDate"
  [locale]="'fa'"
  [minDate]="minDate"
  [maxDate]="maxDate"
  [disabled]="false"
  [placeholder]="'تاریخ را انتخاب کنید'"
  (dateSelect)="onDateSelect($event)"
  (localeChange)="onLocaleChange($event)">
</jalali-date-picker>

// در کامپوننت:
minDate = new Date(2020, 0, 1);
maxDate = new Date(2030, 11, 31);

onLocaleChange(locale: string) {
  console.log('زبان تغییر کرد:', locale);
}`,
